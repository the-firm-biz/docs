                      "setting-max-price",
                      "order-validity"
                    ]
                  }
                ]
              },
              "wallets-and-funds"
            ]
          },
          {
            "group": "For Projects",
            "expanded": true,
            "pages": [
              "why-launch",
              "register-a-launch",
              "supported-launchpads"
            ]
          },
          {
            "group": "How Auto-Buys Work",
            "pages": [
              {
                "group": "Types of Auto-Buy",
                "pages": [
                  "token-launch-types",
                  "open-market-buys",
                  "dev-buys",
                  "otc-buys",
                  "how-does-auto-boy-work",
                  "how-fast-is-auto-boy"
                ]
              },
              {
                "group": "Order Settlement",
                "pages": [
                  "order-prioritization",
                  "mcap-calculation"
                ]
              },
              "fees"
            ]
          },
          {
            "group": "REST API",
            "expanded": true,
            "pages": [
              "auto-boy-api"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "links",
              "contact"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://thefirm.biz/api/public/v1/openapi.json"
      }
